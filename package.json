{
  "name": "universal-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs all",
    "dev:web": "node scripts/dev.mjs web",
    "dev:api": "node scripts/dev.mjs api",
    "ports": "node scripts/ports.mjs",
    "stop": "node scripts/stop.mjs",
    "build": "turbo run build && node scripts/check-bundle-size.mjs && node scripts/check-bundle-secrets.mjs",
    "budget": "node scripts/check-bundle-size.mjs",
    "clean": "cargo clean --manifest-path apps/shell/src-tauri/Cargo.toml && node scripts/clean.mjs",
    "test": "turbo run test && node --test \"scripts/*.test.mjs\"",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "arch": "depcruise --config .dependency-cruiser.cjs --output-type err apps packages",
    "size": "node scripts/check-file-size.mjs",
    "bindings": "cargo run --quiet --manifest-path apps/shell/src-tauri/Cargo.toml --bin export_bindings",
    "bindings:check": "node scripts/check-bindings.mjs",
    "security": "node scripts/check-security.mjs",
    "rename": "node scripts/rename.mjs",
    "template": "node scripts/check-template.mjs",
    "audit:rust": "cd apps/shell/src-tauri && cargo audit --deny warnings && cargo deny check",
    "audit:deps": "pnpm audit && pnpm audit:rust",
    "dup": "jscpd",
    "knip": "knip",
    "check": "pnpm typecheck && pnpm test && pnpm lint && pnpm arch && pnpm size && pnpm dup && pnpm knip && pnpm security && pnpm template && pnpm bindings:check",
    "gen": "turbo gen",
    "desktop": "node scripts/shell.mjs desktop",
    "desktop:build": "pnpm --filter @repo/shell tauri build",
    "mobile:ios": "node scripts/shell.mjs ios",
    "mobile:android": "node scripts/shell.mjs android",
    "db:generate": "pnpm --filter @repo/db exec drizzle-kit generate",
    "prepare": "lefthook install || exit 0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@turbo/gen": "^2.10.5",
    "dependency-cruiser": "^18.1.0",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "lefthook": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
