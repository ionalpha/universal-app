{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Universal App",
  "version": "0.0.0",
  "identifier": "com.ionalpha.universalapp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Universal App",
        "width": 1000,
        "height": 700,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:8787; object-src 'none'; frame-src 'none'; child-src 'none'; frame-ancestors 'none'; worker-src 'self'; base-uri 'self'; form-action 'none'",
      "freezePrototype": true,
      "assetProtocol": {
        "enable": false,
        "scope": []
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
